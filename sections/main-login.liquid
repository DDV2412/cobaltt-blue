{% comment %} Customer Login Section {% endcomment %}

<div class="auth-box">
  <h1>{{ 'customer.login.title' | t }}</h1>
  {%- form 'customer_login' -%}
    {%- if form.errors -%}
      <p class="form-error" role="alert">{{ form.errors | default_errors }}</p>
    {%- endif -%}
    <div class="form-group">
      <label class="form-label" for="CustomerEmail">{{ 'customer.login.email' | t }}</label>
      <input type="email" name="customer[email]" id="CustomerEmail" class="form-input" value="{{ form.email }}" required autocomplete="email" aria-required="true">
    </div>
    <div class="form-group">
      <label class="form-label" for="CustomerPassword">{{ 'customer.login.password' | t }}</label>
      <input type="password" name="customer[password]" id="CustomerPassword" class="form-input" required autocomplete="current-password" aria-required="true">
    </div>
    <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-bottom:12px;">{{ 'customer.login.sign_in' | t }} <span class="arrow" aria-hidden="true">↗</span></button>
    <a href="{{ routes.account_recover_url }}" class="auth-link" style="display:block;">{{ 'customer.login.forgot_password' | t }}</a>
  {%- endform -%}
  <p class="auth-link" style="margin-top:20px;">{{ 'customer.login.guest_title' | t }} <a href="{{ routes.account_register_url }}">{{ 'customer.login.create_account' | t }}</a></p>
</div>

{% schema %}
{
  "name": "Login",
  "tag": "section",
  "class": "section-main-login",
  "settings": [],
  "blocks": [],
  "presets": [{ "name": "Login" }]
}
{% endschema %}
