{% comment %} Footer Section {% endcomment %}

<footer class="footer" role="contentinfo">
  <div class="footer-grid">
    <!-- Brand column -->
    <div class="footer-brand">
      <a href="{{ routes.root_url }}" class="footer-brand-name" aria-label="{{ shop.name }}">
        {{ section.settings.brand_name | default: shop.name }}
      </a>

      {%- if section.settings.show_social -%}
        <div class="footer-social">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" rel="nofollow noopener" target="_blank" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_youtube_link != blank -%}
            <a href="{{ settings.social_youtube_link }}" rel="nofollow noopener" target="_blank" aria-label="YouTube">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-2C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 2A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            <a href="{{ settings.social_tiktok_link }}" rel="nofollow noopener" target="_blank" aria-label="TikTok">TK</a>
          {%- endif -%}
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" rel="nofollow noopener" target="_blank" aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_twitter_link != blank -%}
            <a href="{{ settings.social_twitter_link }}" rel="nofollow noopener" target="_blank" aria-label="Twitter/X">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>

    <!-- Nav columns -->
    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' -%}
        <div class="footer-col" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h5>{{ block.settings.heading | upcase }}</h5>
          {%- endif -%}
          {%- if block.settings.menu != blank -%}
            {%- for link in linklists[block.settings.menu].links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="footer-bottom">
    <div>
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
      {{ 'general.footer.copyright' | t | default: 'All rights reserved.' }}
    </div>
    <div class="links">
      {%- if section.settings.footer_menu != blank -%}
        {%- for link in linklists[section.settings.footer_menu].links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_locale_selector or section.settings.show_country_selector -%}
    <div style="padding-top:20px;max-width:1312px;margin:0 auto;">
      {%- form 'localization', id: 'FooterLocalizationForm' -%}
        <div class="locale-form">
          {%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
            <label for="FooterCountrySelector" class="visually-hidden">{{ 'localization.country_label' | t }}</label>
            <select name="country_code" id="FooterCountrySelector" class="form-select" aria-label="{{ 'localization.country_label' | t }}">
              {%- for country in localization.available_countries -%}
                <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                  {{ country.name }} ({{ country.currency.iso_code }})
                </option>
              {%- endfor -%}
            </select>
          {%- endif -%}
          {%- if section.settings.show_locale_selector and localization.available_languages.size > 1 -%}
            <label for="FooterLanguageSelector" class="visually-hidden">{{ 'localization.language_label' | t }}</label>
            <select name="locale_code" id="FooterLanguageSelector" class="form-select" aria-label="{{ 'localization.language_label' | t }}">
              {%- for language in localization.available_languages -%}
                <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                  {{ language.endonym_name | capitalize }}
                </option>
              {%- endfor -%}
            </select>
          {%- endif -%}
        </div>
      {%- endform -%}
    </div>
  {%- endif -%}

  {%- if section.settings.show_payment_icons -%}
    <div style="padding-top:16px;max-width:1312px;margin:0 auto;display:flex;gap:8px;flex-wrap:wrap;">
      {%- for type in shop.enabled_payment_types -%}
        {{ type | payment_type_svg_tag: class: 'payment-icon' }}
      {%- endfor -%}
    </div>
  {%- endif -%}
</footer>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
  .payment-icon { height: 24px; width: auto; }
</style>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "COBALT.BLUE"
    },
    {
      "type": "textarea",
      "id": "brand_desc",
      "label": "Brand description",
      "default": "Professional-grade ceramic car coating. Engineered for enthusiasts, usable by anyone."
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social media icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Footer navigation"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer bottom menu",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Localization"
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "Show country selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_locale_selector",
      "label": "Show language selector",
      "default": true
    },
    {
      "type": "header",
      "content": "Payment"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Navigation column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "main-menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": { "heading": "Product", "menu": "main-menu" }
      },
      {
        "type": "link_list",
        "settings": { "heading": "Learn", "menu": "main-menu" }
      },
      {
        "type": "link_list",
        "settings": { "heading": "Support", "menu": "footer" }
      }
    ]
  }
}
{% endschema %}
