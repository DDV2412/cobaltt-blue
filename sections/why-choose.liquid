          }
        },
        {
          "type": "feature",
          "settings": {
            "side": "left",
            "title": "Award-Winning",
            "description": "Rated #1 for hydrophobicity in 2024 by AutoDetail Magazine across 18 competing products.",
            "icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M6 9a6 6 0 1 0 12 0V3H6v6z\"/><path d=\"M8 21h8M12 15v6M6 4H3v3a3 3 0 0 0 3 3M18 4h3v3a3 3 0 0 1-3 3\"/></svg>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "side": "left",
            "title": "DIY Engineered",
            "description": "5-minute working window with clear flash indicators — professional results in your driveway.",
            "icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7c1 .9 1.5 1.6 1.5 2.8V18h5v-.5c0-1.2.5-1.9 1.5-2.8A7 7 0 0 0 12 2z\"/></svg>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "side": "right",
            "title": "5-Year Protection",
            "description": "Ceramic network bonds at the molecular level — won't wash off or degrade for 5+ years.",
            "icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6l-8-4z\"/><path d=\"m9 12 2 2 4-4\"/></svg>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "side": "right",
            "title": "Eco-Responsible",
