{% comment %} Why Choose Section — with fade-in car image + glowing rings {% endcomment %}

<section class="section" id="{{ section.settings.section_id | default: 'why' }}" aria-labelledby="why-heading">
  <div class="section-head reveal">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h2 id="why-heading">{{ section.settings.heading | default: 'WHY CHOOSE COBALT BLUE' }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p>{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="why-body">
    <!-- Left column -->
    <div class="why-col left">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' and block.settings.side == 'left' -%}
          <div class="why-feature reveal" {{ block.shopify_attributes }}>
            <div>
              {%- if block.settings.title != blank -%}
                <h4>{{ block.settings.title | upcase }}</h4>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p>{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
            <div class="icon" aria-hidden="true">
              {%- if block.settings.icon_svg != blank -%}
                {{ block.settings.icon_svg }}
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3.5"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Center: car image with solid rings -->
    <div class="why-center" aria-hidden="true">
      <div class="ring r2"></div>
      <div class="ring r1"></div>
      {%- if section.settings.center_image != blank -%}
        <img
          src="{{ section.settings.center_image | image_url: width: 540 }}"
          alt="{{ section.settings.center_image.alt | default: 'Coated vehicle' }}"
          class="why-center__img"
          width="540"
          height="360"
          loading="lazy"
        >
      {%- else -%}
        <img
          src="{{ 'car.png' | asset_url }}"
          alt="Ceramic coated vehicle"
          class="why-center__img"
          width="540"
          height="360"
          loading="lazy"
        >
      {%- endif -%}
    </div>

    <!-- Right column -->
    <div class="why-col right">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' and block.settings.side == 'right' -%}
          <div class="why-feature reveal" {{ block.shopify_attributes }}>
            <div class="icon" aria-hidden="true">
              {%- if block.settings.icon_svg != blank -%}
                {{ block.settings.icon_svg }}
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6l-8-4z"/></svg>
              {%- endif -%}
            </div>
            <div>
              {%- if block.settings.title != blank -%}
                <h4>{{ block.settings.title | upcase }}</h4>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p>{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why choose",
  "tag": "section",
  "class": "section-why-choose",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID (for scroll targeting)",
      "default": "why"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The Cobalt Difference"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHY CHOOSE COBALT BLUE"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We didn't just bottle a coating. We spent three years engineering a formula that outperforms on every metric that matters."
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center vehicle image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "side",
          "label": "Column side",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Short description of this feature benefit."
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG",
          "info": "Paste an SVG icon (24x24 recommended)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why choose",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "side": "left",
            "title": "Lab-Grade Formula",
