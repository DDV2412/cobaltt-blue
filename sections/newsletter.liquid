{% comment %} Newsletter Section {% endcomment %}

<section class="newsletter-section" aria-labelledby="newsletter-heading">
  <div class="newsletter-inner reveal">
    {%- if section.settings.eyebrow != blank -%}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h2 id="newsletter-heading">{{ section.settings.heading | default: 'JOIN THE CLUB' }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p>{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'newsletter-section-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {%- if form.posted_successfully? -%}
        <p class="form-success" role="alert">{{ 'newsletter.success' | t | default: 'Thank you! Check your inbox.' }}</p>
      {%- else -%}
        {%- if form.errors -%}
          <p class="form-error" role="alert">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
        {%- endif -%}
        <div class="newsletter-form">
          <label for="newsletter-email" class="visually-hidden">{{ 'newsletter.label' | t | default: 'Email address' }}</label>
          <input
            type="email"
            name="contact[email]"
            id="newsletter-email"
            value="{{ form.email }}"
            placeholder="{{ section.settings.placeholder | default: 'Your email address' }}"
            required
            autocomplete="email"
            aria-required="true"
          >
          <button type="submit" class="btn btn-primary btn-pill-sm">
            {{ section.settings.btn_label | default: 'Subscribe' }}
          </button>
        </div>
      {%- endif -%}
    {%- endform -%}

    {%- if section.settings.disclaimer != blank -%}
      <p style="font-size:11px;color:var(--text-3);margin-top:12px;letter-spacing:0.08em;">{{ section.settings.disclaimer }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Stay in the know"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN THE CLUB"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get exclusive tips, early access to new products, and members-only discounts."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer text",
      "default": "No spam. Unsubscribe anytime."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
