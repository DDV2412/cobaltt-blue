{% comment %} Main Page Section {% endcomment %}

<div class="page-section">
  <h1>{{ page.title }}</h1>
  <div class="page-content rte">{{ page.content }}</div>
</div>

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "class": "section-main-page",
  "settings": [],
  "blocks": [
    { "type": "@app" },
    {
      "type": "custom_liquid",
      "name": "Custom Liquid",
      "settings": [
        { "type": "liquid", "id": "custom_liquid", "label": "Custom Liquid" }
      ]
    }
  ],
  "presets": [{ "name": "Page" }]
}
{% endschema %}
