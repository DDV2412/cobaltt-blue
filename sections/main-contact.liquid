{% comment %} Contact Page Section {% endcomment %}

<div class="page-section">
  <h1>{{ page.title }}</h1>
  {%- if page.content != blank -%}
    <div class="page-content rte" style="margin-bottom:40px;">{{ page.content }}</div>
  {%- endif -%}

  {%- form 'contact', id: 'ContactForm' -%}
    {%- if form.posted_successfully? -%}
      <p class="form-success" role="alert">{{ 'contact.form.post_success' | t }}</p>
    {%- else -%}
      {%- if form.errors -%}
        <p class="form-error" role="alert">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div class="contact-form">
        <div class="form-group">
          <label class="form-label" for="ContactFormName">{{ 'contact.form.name' | t }}</label>
          <input
            type="text"
            name="contact[name]"
            id="ContactFormName"
            class="form-input"
            value="{{ form.name }}"
            autocomplete="name"
          >
        </div>
        <div class="form-group">
          <label class="form-label" for="ContactFormEmail">{{ 'contact.form.email' | t }} *</label>
          <input
            type="email"
            name="contact[email]"
            id="ContactFormEmail"
            class="form-input"
            value="{{ form.email }}"
            required
            autocomplete="email"
            aria-required="true"
          >
        </div>
        <div class="form-group">
          <label class="form-label" for="ContactFormMessage">{{ 'contact.form.message' | t }}</label>
          <textarea
            name="contact[body]"
            id="ContactFormMessage"
            class="form-textarea"
          >{{ form.body }}</textarea>
        </div>
        <button type="submit" class="btn btn-primary">
          {{ 'contact.form.send' | t }}
          <span class="arrow" aria-hidden="true">↗</span>
        </button>
      </div>
    {%- endif -%}
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Contact form",
  "tag": "section",
  "class": "section-main-contact",
  "settings": [],
  "blocks": [],
  "presets": [{ "name": "Contact form" }]
}
{% endschema %}
