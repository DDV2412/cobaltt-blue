{% comment %} Contact Page Section {% endcomment %}

<section class="contact-section" aria-labelledby="contact-heading">
  <div class="contact-inner">
    <!-- Left: info -->
    <div class="contact-info">
      <div class="eyebrow">{{ section.settings.eyebrow | default: 'Get in Touch' }}</div>
      <h1 id="contact-heading">{{ page.title | default: section.settings.heading | default: 'CONTACT US' }}</h1>
      {%- if page.content != blank -%}
        <div class="contact-info__desc rte">{{ page.content }}</div>
      {%- elsif section.settings.description != blank -%}
        <p class="contact-info__desc">{{ section.settings.description }}</p>
      {%- else -%}
        <p class="contact-info__desc">Have a question about your order, our products, or need application support? We're here to help.</p>
      {%- endif -%}

      <div class="contact-details">
        {%- if section.settings.email != blank -%}
          <div class="contact-detail">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
          </div>
        {%- endif -%}
        {%- if section.settings.response_time != blank -%}
          <div class="contact-detail">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{{ section.settings.response_time }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- Right: form -->
    <div class="contact-form-wrap">
      {%- form 'contact', id: 'ContactForm' -%}
        {%- if form.posted_successfully? -%}
          <div class="contact-success" role="alert">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {{ 'contact.form.post_success' | t }}
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <p class="form-error" role="alert">{{ form.errors | default_errors }}</p>
          {%- endif -%}
          <div class="contact-form-grid">
            <div class="form-group">
              <label class="form-label" for="ContactFormName">{{ 'contact.form.name' | t }}</label>
              <input
                type="text"
                name="contact[name]"
                id="ContactFormName"
                class="form-input"
                value="{{ form.name }}"
                autocomplete="name"
                placeholder="Your full name"
              >
            </div>
            <div class="form-group">
              <label class="form-label" for="ContactFormEmail">{{ 'contact.form.email' | t }} <span aria-hidden="true">*</span></label>
              <input
                type="email"
                name="contact[email]"
                id="ContactFormEmail"
                class="form-input"
                value="{{ form.email }}"
                required
                autocomplete="email"
                aria-required="true"
                placeholder="you@example.com"
              >
            </div>
            <div class="form-group form-group--full">
              <label class="form-label" for="ContactFormSubject">{{ 'contact.form.subject' | t | default: 'Subject' }}</label>
              <input
                type="text"
                name="contact[subject]"
                id="ContactFormSubject"
                class="form-input"
                placeholder="How can we help?"
              >
            </div>
            <div class="form-group form-group--full">
              <label class="form-label" for="ContactFormMessage">{{ 'contact.form.message' | t }}</label>
              <textarea
                name="contact[body]"
                id="ContactFormMessage"
                class="form-textarea"
                placeholder="Tell us more about your question or issue…"
                rows="5"
              >{{ form.body }}</textarea>
            </div>
          </div>
          <button type="submit" class="btn btn-primary">
            {{ 'contact.form.send' | t }}
            <span class="arrow" aria-hidden="true">↗</span>
          </button>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact form",
  "tag": "section",
  "class": "section-main-contact",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Get in Touch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (fallback if no page title)",
      "default": "CONTACT US"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Have a question about your order, our products, or need application support? We're here to help."
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email",
      "default": "support@cobaltblue.com"
    },
    {
      "type": "text",
      "id": "response_time",
      "label": "Response time text",
      "default": "We reply within 24 hours"
    }
  ],
  "blocks": [],
  "presets": [{ "name": "Contact form" }]
}
{% endschema %}
