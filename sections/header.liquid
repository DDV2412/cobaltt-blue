{% comment %} Header Section {% endcomment %}

<header class="nav" id="nav" role="banner">
  {%- if section.settings.logo != blank -%}
    <a href="{{ routes.root_url }}" class="nav-logo" aria-label="{{ shop.name }}">
      <img
        src="{{ section.settings.logo | image_url: height: 56 }}"
        alt="{{ section.settings.logo.alt | default: shop.name }}"
        width="{{ section.settings.logo | image_url: height: 56 | split: 'width=' | last | split: '&' | first }}"
        height="56"
        loading="eager"
      >
    </a>
  {%- else -%}
    <a href="{{ routes.root_url }}" class="nav-logo" aria-label="{{ shop.name }}">
      <img src="{{ 'Cobalt-text-white-color.png' | asset_url }}" alt="{{ shop.name }}" height="36" loading="eager">
    </a>
  {%- endif -%}

  {%- if section.settings.menu != blank -%}
    <nav class="nav-links" aria-label="{{ 'accessibility.nav.main_menu' | t }}">
      {%- for link in linklists[section.settings.menu].links -%}
        {%- if link.links.size > 0 -%}
          <div class="nav-item">
            <a
              href="{{ link.url }}"
              class="nav-link"
              aria-haspopup="true"
              aria-expanded="false"
            >{{ link.title }}</a>
            <div class="nav-dropdown" role="menu">
              {%- for child in link.links -%}
                <a href="{{ child.url }}" role="menuitem">{{ child.title }}</a>
              {%- endfor -%}
            </div>
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="nav-link" {% if link.active %}aria-current="page"{% endif %}>{{ link.title }}</a>
        {%- endif -%}
      {%- endfor -%}
    </nav>
  {%- endif -%}

  <div class="nav-right">
    {%- if section.settings.show_search -%}
      <button
        class="nav-search-btn"
        id="searchOpenBtn"
        data-open-search
        aria-label="{{ 'general.search.search' | t }}"
        aria-controls="searchModal"
        aria-expanded="false"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    {%- endif -%}

    <button
      class="cart-btn"
      id="cartOpenBtn"
      data-open-cart
      aria-label="{{ 'cart.title' | t }}"
      aria-controls="cartDrawer"
      aria-expanded="false"
    >
      {{ 'cart.title' | t }}
      <span class="cart-count" id="cartCount" aria-live="polite">{{ cart.item_count }}</span>
    </button>

    {%- if section.settings.show_buy_btn -%}
      <a href="{{ section.settings.buy_btn_url | default: routes.all_products_collection_url }}" class="btn btn-primary btn-pill-sm">
        {{ section.settings.buy_btn_label | default: 'Buy Now' }}
        <span class="arrow" aria-hidden="true">↗</span>
      </a>
    {%- endif -%}

    <button
      class="nav-mobile-toggle"
      id="mobileNavToggle"
      aria-label="{{ 'accessibility.nav.open_mobile_menu' | t }}"
      aria-controls="mobileNavDrawer"
      aria-expanded="false"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
</header>

<!-- Mobile Nav Drawer -->
<nav class="mobile-nav-drawer" id="mobileNavDrawer" aria-label="{{ 'accessibility.nav.mobile_menu' | t }}" aria-hidden="true">
  <div class="mobile-nav-header">
    {%- if section.settings.logo != blank -%}
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        <img src="{{ section.settings.logo | image_url: height: 40 }}" alt="{{ shop.name }}" height="40">
      </a>
    {%- else -%}
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        <img src="{{ 'Cobalt-text-white-color.png' | asset_url }}" alt="{{ shop.name }}" height="30" loading="eager">
      </a>
    {%- endif -%}
    <button class="mobile-nav-close" id="mobileNavClose" aria-label="{{ 'accessibility.close' | t }}">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <div class="mobile-nav-links">
    {%- if section.settings.menu != blank -%}
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}" class="mobile-nav-link">{{ link.title }}</a>
        {%- if link.links.size > 0 -%}
          {%- for child in link.links -%}
            <a href="{{ child.url }}" class="mobile-nav-link" style="padding-left:28px;font-size:14px;opacity:0.75;">{{ child.title }}</a>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </div>

  <div class="mobile-nav-actions">
    <button class="btn btn-ghost" data-open-cart>
      {{ 'cart.title' | t }} ({{ cart.item_count }})
    </button>
    {%- if section.settings.show_buy_btn -%}
      <a href="{{ section.settings.buy_btn_url | default: routes.all_products_collection_url }}" class="btn btn-primary">
        {{ section.settings.buy_btn_label | default: 'Buy Now' }}
        <span class="arrow" aria-hidden="true">↗</span>
      </a>
    {%- endif -%}
  </div>
</nav>

<!-- Search Modal -->
{%- if section.settings.show_search -%}
<div class="search-modal" id="searchModal" role="dialog" aria-modal="true" aria-label="{{ 'general.search.search' | t }}" aria-hidden="true">
  <div class="search-modal__inner">
    <form action="{{ routes.search_url }}" method="get" class="search-modal__input-wrap" role="search">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input
        type="search"
        name="q"
        id="searchModalInput"
        class="search-modal__input"
        placeholder="{{ 'general.search.placeholder' | t | default: 'Search products, pages…' }}"
        autocomplete="off"
        aria-label="{{ 'general.search.search' | t }}"
      >
      <input type="hidden" name="type" value="product,article,page">
      <button type="button" class="search-modal__close" id="searchModalClose" aria-label="{{ 'accessibility.close' | t }}">✕</button>
    </form>
    <div class="search-modal__results" id="searchModalResults" aria-live="polite">
      <p class="search-modal__empty">{{ 'general.search.start_typing' | t | default: 'Start typing to search…' }}</p>
    </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_buy_btn",
      "label": "Show buy button",
      "default": true
    },
    {
      "type": "text",
      "id": "buy_btn_label",
      "label": "Buy button label",
      "default": "Buy Now"
    },
    {
      "type": "url",
      "id": "buy_btn_url",
      "label": "Buy button URL"
    }
  ],
  "blocks": []
}
{% endschema %}
