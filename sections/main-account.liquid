{% comment %} Customer Account Section {% endcomment %}

<div class="customer-section">
  <h1>{{ 'customer.account.title' | t }}</h1>
  <div class="account-grid">
    <!-- Order history -->
    <div class="account-card" style="grid-column:1/-1;">
      <h2>{{ 'customer.orders.title' | t }}</h2>
      {%- if customer.orders.size > 0 -%}
        <table class="order-table">
          <thead>
            <tr>
              <th scope="col">{{ 'customer.orders.order_number' | t }}</th>
              <th scope="col">{{ 'customer.orders.date' | t }}</th>
              <th scope="col">{{ 'customer.orders.payment_status' | t }}</th>
              <th scope="col">{{ 'customer.orders.fulfillment_status' | t }}</th>
              <th scope="col">{{ 'customer.orders.total' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {%- for order in customer.orders -%}
              <tr>
                <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
                <td>{{ order.created_at | date: '%B %d, %Y' }}</td>
                <td>{{ order.financial_status_label }}</td>
                <td>{{ order.fulfillment_status_label }}</td>
                <td>
                  {{ order.total_net_amount | money }}
                  {%- for line in order.line_items -%}
                    {%- if line.selling_plan_allocation -%}
                      <span style="display:block;font-size:11px;color:var(--blue-l);">{{ line.selling_plan_allocation.selling_plan.name }}</span>
                    {%- endif -%}
                  {%- endfor -%}
                </td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      {%- else -%}
        <p style="color:var(--text-2);">{{ 'customer.orders.none' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary btn-pill-sm" style="margin-top:16px;">{{ 'general.continue_shopping' | t | default: 'Shop Now' }}</a>
      {%- endif -%}
    </div>

    <!-- Address -->
    <div class="account-card">
      <h2>{{ 'customer.account.details' | t }}</h2>
      <p style="font-size:14px;color:var(--text-2);">{{ customer.email }}</p>
      <p style="font-size:14px;color:var(--text-2);">{{ customer.first_name }} {{ customer.last_name }}</p>
      <a href="{{ routes.account_addresses_url }}" class="btn btn-ghost btn-pill-sm" style="margin-top:16px;">{{ 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }})</a>
    </div>

    <!-- Follow on Shop -->
    {%- if settings.show_follow_on_shop -%}
      <div class="account-card">
        <h2>{{ 'customer.account.follow' | t | default: 'Follow on Shop' }}</h2>
        <div class="shop-login-button">
          {{ shop | login_button: action: 'follow' }}
        </div>
      </div>
    {%- endif -%}
  </div>
  <div style="margin-top:28px;">
    <a href="{{ routes.account_logout_url }}" class="btn btn-ghost btn-pill-sm">{{ 'customer.account.logout' | t }}</a>
  </div>
</div>

{% schema %}
{
  "name": "Account",
  "tag": "section",
  "class": "section-main-account",
  "settings": [],
  "blocks": [],
  "presets": [{ "name": "Account" }]
}
{% endschema %}
