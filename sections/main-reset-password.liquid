{% comment %} Reset Password Section {% endcomment %}

<div class="auth-box">
  <h1>{{ 'customer.recover_password.title' | t }}</h1>
  {%- if recover_success -%}
    <p class="form-success" role="alert">{{ 'customer.recover_password.success' | t }}</p>
  {%- else -%}
    <p style="color:var(--text-2);margin-bottom:24px;">{{ 'customer.recover_password.subtext' | t }}</p>
    {%- form 'recover_customer_password' -%}
      {%- if form.errors -%}
        <p class="form-error" role="alert">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div class="form-group">
        <label class="form-label" for="RecoverEmail">{{ 'customer.recover_password.email' | t }} *</label>
        <input type="email" name="email" id="RecoverEmail" class="form-input" value="{{ form.email }}" required autocomplete="email" aria-required="true">
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">{{ 'customer.recover_password.submit' | t }} <span class="arrow" aria-hidden="true">↗</span></button>
    {%- endform -%}
  {%- endif -%}
  <p class="auth-link" style="margin-top:16px;"><a href="{{ routes.account_login_url }}">← {{ 'customer.recover_password.cancel' | t }}</a></p>
</div>

{% schema %}
{
  "name": "Reset password",
  "tag": "section",
  "class": "section-main-reset-password",
  "settings": [],
  "blocks": [],
  "presets": [{ "name": "Reset password" }]
}
{% endschema %}
