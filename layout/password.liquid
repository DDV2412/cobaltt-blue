<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ shop.description | escape }}">
  <title>{{ shop.name }} &mdash; {{ 'general.password_page.title' | t }}</title>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  {%- assign font_body = settings.font_body -%}

  <style>
    @font-face {
      font-family: 'League Gothic';
      src: url('{{ 'LeagueGothic-Regular.woff2' | asset_url }}') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    {{ font_body | font_face: font_display: 'swap' }}
    :root {
      --font-heading: 'League Gothic', sans-serif;
      --font-body: {{ font_body.family | json }}, {{ font_body.fallback_families }};
    }
  </style>

  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body class="template-password">
  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>
  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
